# JananiSuraksha Environment Variables
# Copy this file to .env and fill in your values

# Google Maps API Key (enable Maps JavaScript API in GCP console)
# Get from: https://console.cloud.google.com/apis/credentials
JANANI_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# data.gov.in API Key (free registration)
# Get from: https://data.gov.in/ogpl/apis
JANANI_DATA_GOV_API_KEY=your-data-gov-api-key-here
